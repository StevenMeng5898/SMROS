<vm name="linux-demo2">
  <cpu time_slice_us="1000" priority="80"></cpu>
  <memory bytes="536870912"></memory>
  <restart policy="on-crash" limit="3"></restart>
  <linux
    kernel="host_shared/linux/Image"
    initrd="host_shared/linux/initrd.img"
    append="console=ttyAMA0 root=/dev/ram0 rw rdinit=/init">
  </linux>
  <qemu
    machine="virt"
    cpu="cortex-a57"
    smp="1"
    memory="512M"
    display="gtk"
    serial="vc">
  </qemu>
  <launcher port="7070"></launcher>
</vm>
